# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fguild"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (inactive on MVP — set ENABLE_BILLING=true to activate)
ENABLE_BILLING=false
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""

# Resend (transactional emails)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="Guild <noreply@yourdomain.com>"

# Email type toggles (set to "true" to disable)
# EMAIL_DISABLE_WELCOME=true
# EMAIL_DISABLE_QUEST_COMPLETED=true
# EMAIL_DISABLE_LEVEL_UP=true
# EMAIL_DISABLE_PRAYER_ANSWER=true

# PostHog Analytics (optional — leave empty to disable)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
